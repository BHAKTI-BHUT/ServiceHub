        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Accept", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"mobile\": \"9876543210\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/api/check-mobile",
          "host": ["{{base_url}}"],
          "path": ["api", "check-mobile"]
        },
        "description": "Step 1: Check karo mobile number exists karta hai ya nahi.\n\nIf exists = true: OTP bhej diya gaya, Verify OTP pe jao.\nIf exists = false: Pehle Register karo.\n\nOTP hamesha 123456 (dummy mode ON hai)."
      },
